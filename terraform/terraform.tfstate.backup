            "upgrade_install": null,
            "values": [
              "resources:\n  - apiVersion: v1\n    kind: ConfigMap\n    metadata:\n      name: terraform-fluxcd-values\n      labels:\n        reconcile.fluxcd.io/watch: Enabled\n      annotations:\n        \"helm.sh/resource-policy\": keep\n    data:\n      values.yaml: |\n        helmRepository:\n          interval: 15m\n          nfsServer:\n            url: oci://cr.eu-north1.nebius.cloud/soperator\n          soperator:\n            url: oci://cr.eu-north1.nebius.cloud/soperator\n        certManager:\n          enabled: true\n          interval: 5m\n          timeout: 5m\n        backup:\n          enabled: true\n          interval: 5m\n          timeout: 5m\n          config:\n            enabled: true\n            version: 4.1.0\n            values:\n              secret:\n                name: jail-backup\n              bucket:\n                endpoint: https://storage.eu-north2.nebius.cloud:443\n                name: soperator-spugachev-backups\n              backup:\n                schedule: \"@daily-random\"\n              prune:\n                schedule: \"@daily-random\"\n              retention:\n                keepDaily: 3\n\n        mariadbOperator:\n          enabled: true\n          interval: 5m\n          timeout: 5m\n          version: 25.10.2\n          values: null\n        observability:\n          enabled: true\n          clusterName: spugachev\n          publicEndpointEnabled: false\n          region: eu-north2\n          opentelemetry:\n            enabled: true\n            logs:\n              values:\n                resources:\n                  requests:\n                    memory: 200Mi\n                    cpu: 200m\n                  limits:\n                    memory: 200Mi\n                jailLogs:\n                  enabled: true\n                  resources:\n                    requests:\n                      memory: 1Gi\n                      cpu: 1000m\n                    limits:\n                      memory: 1Gi\n\n            events:\n              interval: 5m\n              timeout: 5m\n              values:\n                resources:\n                  requests:\n                    memory: 128Mi\n                    cpu: 100m\n                  limits:\n                    memory: 128Mi\n          prometheusOperator:\n            enabled: true\n            interval: 5m\n            timeout: 5m\n          vmStack:\n            enabled: true\n            crds:\n              interval: 5m\n              timeout: 5m\n            interval: 5m\n            timeout: 5m\n            values:\n              vmagent:\n                spec:\n                  extraArgs:\n                    promscrape.maxScrapeSize: \"33554432\"\n                  externalLabels:\n                    iam_tenant_id: tenant-e00znpks4hqd7c0e72\n                    iam_project_id: project-e02qk7z0pr005jndcar132\n                    mk8s_cluster_id: mk8scluster-e02fv10y8fh5nghh2m\n                  resources:\n                    requests:\n                      memory: 10Gi\n                      cpu: 5000m\n                    limits:\n                      memory: 10Gi\n              vmsingle:\n                spec:\n                  extraArgs:\n                    dedup.minScrapeInterval: 30s\n                    maxLabelsPerTimeseries: \"40\"\n                    search.maxQueryLen: \"18765\"\n                    search.maxUniqueTimeseries: \"500000\"\n                  retentionPeriod: 7d\n                  extraEnvs:\n                  - name: GOMAXPROCS\n                    value: \"6\"\n                  storage:\n                    accessModes:\n                      - ReadWriteOnce\n                    resources:\n                      requests:\n                        storage: 512Gi\n                  resources:\n                    requests:\n                      memory: 24Gi\n                      cpu: 6000m\n                    limits:\n                      memory: 24Gi\n              prometheusNodeExporter:\n                enabled: true\n                extraArgs:\n                  - '--collector.ethtool.device-exclude=ibp.*'\n                  - '--no-collector.infiniband'\n          vmLogs:\n            enabled: true\n            interval: 5m\n            timeout: 5m\n            values:\n              persistentVolume:\n                enabled: true\n                size: 256Gi\n                accessMode: ReadWriteOnce\n              resources:\n                requests:\n                  memory: 2Gi\n                  cpu: 1000m\n                limits:\n                  memory: 2Gi\n          dcgmExporter:\n            enabled: true\n            version: 4.1.0\n            values:\n              hpcJobMapDir: /var/run/nebius/slurm\n              # waits for nvidia toolkit when not running on preinstalled gpu drivers, so opposite of use_preinstalled_gpu_drivers\n              validateToolkit: false\n              resources:\n                requests:\n                  memory: 0.5Gi\n                  cpu: 0.05m\n                limits:\n                  memory: 0.5Gi\n\n        securityProfilesOperator:\n          enabled: true\n          interval: 5m\n          timeout: 5m\n          values:\n            daemon:\n              resources:\n                limits:\n                  memory: 128Mi\n                requests:\n                  cpu: 100m\n                  memory: 128Mi\n            resources:\n              limits:\n                cpu: 500m\n                memory: 3Gi\n              requests:\n                cpu: 500m\n                memory: 3Gi\n        slurmCluster:\n          enabled: true\n          interval: 5m\n          timeout: 5m\n          version: 4.1.0\n          namespace: soperator\n          releaseName: soperator\n          overrideValues:\n            clusterName: soperator\n            cudaVersion: 13.0.2\n            useDefaultAppArmorProfile: true\n            maintenance: none\n\n\n            partitionConfiguration:\n              configType: structured\n              partitions:\n                - name: main\n                  isAll: true\n                  config: \"Default=YES PriorityTier=10 PreemptMode=OFF MaxTime=INFINITE State=UP OverSubscribe=YES\"\n                - name: hidden\n                  isAll: true\n                  config: \"Default=NO PriorityTier=10 PreemptMode=OFF Hidden=YES MaxTime=INFINITE State=UP OverSubscribe=YES\"\n\n\n            k8sNodeFilters:\n              - name: system\n                affinity:\n                  nodeAffinity:\n                    requiredDuringSchedulingIgnoredDuringExecution:\n                      nodeSelectorTerms:\n                        - matchExpressions:\n                            - key: slurm.nebius.ai/nodeset\n                              operator: In\n                              values:\n                                - system\n\n              - name: accounting\n                affinity:\n                  nodeAffinity:\n                    requiredDuringSchedulingIgnoredDuringExecution:\n                      nodeSelectorTerms:\n                        - matchExpressions:\n                            - key: slurm.nebius.ai/nodeset\n                              operator: In\n                              values:\n                                - accounting\n                tolerations:\n                  - key: slurm.nebius.ai/nodeset\n                    operator: Equal\n                    value: accounting\n                    effect: NoSchedule\n\n              - name: controller\n                affinity:\n                  nodeAffinity:\n                    requiredDuringSchedulingIgnoredDuringExecution:\n                      nodeSelectorTerms:\n                        - matchExpressions:\n                            - key: slurm.nebius.ai/nodeset\n                              operator: In\n                              values:\n                                - controller\n                tolerations:\n                  - key: slurm.nebius.ai/nodeset\n                    operator: Equal\n                    value: controller\n                    effect: NoSchedule\n\n              - name: login\n                affinity:\n                  nodeAffinity:\n                    requiredDuringSchedulingIgnoredDuringExecution:\n                      nodeSelectorTerms:\n                        - matchExpressions:\n                            - key: slurm.nebius.ai/nodeset\n                              operator: In\n                              values:\n                                - login\n                tolerations:\n                  - key: slurm.nebius.ai/nodeset\n                    operator: Equal\n                    value: login\n                    effect: NoSchedule\n\n              - name: worker\n                affinity:\n                  nodeAffinity:\n                    requiredDuringSchedulingIgnoredDuringExecution:\n                      nodeSelectorTerms:\n                        - matchExpressions:\n                            - key: slurm.nebius.ai/nodeset\n                              operator: In\n                              values:\n                                - \"worker-0\"\n                tolerations:\n                  - key: slurm.nebius.ai/nodeset\n                    operator: Equal\n                    value: worker\n                    effect: NoSchedule\n                  - key: nvidia.com/gpu\n                    operator: Exists\n                    effect: NoSchedule\n\n            volumeSources:\n              - name: jail\n                persistentVolumeClaim:\n                  claimName: jail-pvc\n                  readOnly: false\n\n              - name: controller-spool\n                persistentVolumeClaim:\n                  claimName: controller-spool-pvc\n                  readOnly: false\n\n              - name: worker-spool\n                emptyDir:\n                  sizeLimit: 382Gi\n\n\n              - name: home-dir\n                createPVC: true\n                storageClassName: nfs\n                size: 42 # capacity is not enforced by neither NFS server nor csi-driver-nfs\n                persistentVolumeClaim:\n                  claimName: \"home-dir\"\n\n              - name: motd-nebius-o11y\n                configMap:\n                  name: motd-nebius-o11y\n                  defaultMode: 500\n\n              - name: jail-submount-data\n                persistentVolumeClaim:\n                  claimName: jail-submount-data-pvc\n                  readOnly: false\n\n              - name: sys-host\n                hostPath:\n                  path: /sys\n                  type: Directory\n\n              - hostPath:\n                  path: /\n                  type: \"\"\n                name: nvidia-driver-root\n\n              - name: hpc-jobs-dir\n                hostPath:\n                  path: /var/run/nebius/slurm\n                  type: DirectoryOrCreate\n\n            populateJail:\n              k8sNodeFilterName: system\n\n            periodicChecks:\n              ncclBenchmark:\n                enabled: false\n                k8sNodeFilterName: system\n\n            slurmNodes:\n              sssd:\n                enabled: false\n                resources:\n                  cpu: 200m\n                  memory: 0.5Gi\n                  ephemeralStorage: 5Gi\n                sssdConfSecretRefName: \"\"\n                sssdLdapCAConfigMapRefName: \"\"\n\n              accounting:\n                enabled: true\n                k8sNodeFilterName: accounting\n                mariadbOperator:\n                  enabled: true\n                  protectedSecret: true\n                  resources:\n                    cpu: 2000m\n                    memory: 12Gi\n                    ephemeralStorage: 16Gi\n                  metrics:\n                    enabled: true\n                  storage:\n                    ephemeral: false\n                    volumeClaimTemplate:\n                      accessModes:\n                        - ReadWriteOnce\n                      resources:\n                        requests:\n                          storage: 100Gi\n                slurmdbd:\n                  resources:\n                    cpu: 12900m\n                    memory: 42.5Gi\n                    ephemeralStorage: 39Gi\n                munge:\n                  resources:\n                    cpu: 100m\n                    memory: 0.5Gi\n                    ephemeralStorage: 5Gi\n                customInitContainers:\n                  - name: ensure-jail-virtiofs\n                    image: cr.eu-north1.nebius.cloud/soperator/busybox\n                    volumeMounts: [{ name: jail, mountPath: /volume-mount }]\n                    command: [\"grep\", \" /volume-mount virtiofs \", \"/proc/mounts\"]\n\n              controller:\n                size: 1\n                k8sNodeFilterName: controller\n                slurmctld:\n                  resources:\n                    cpu: 14000m\n                    memory: 54Gi\n                    ephemeralStorage: 55Gi\n                munge:\n                  resources:\n                    cpu: 100m\n                    memory: 0.5Gi\n                    ephemeralStorage: 5Gi\n                customInitContainers:\n                  - name: ensure-jail-virtiofs\n                    image: cr.eu-north1.nebius.cloud/soperator/busybox\n                    volumeMounts: [{ name: jail, mountPath: /volume-mount }]\n                    command: [\"grep\", \" /volume-mount virtiofs \", \"/proc/mounts\"]\n                volumes:\n                  spool:\n                    volumeClaimTemplateSpec:\n                      accessModes:\n                        - ReadWriteOnce\n                      resources:\n                        requests:\n                          storage: 50Gi\n                      storageClassName: \"compute-csi-network-ssd-ext4\"\n              login:\n                size: 1\n                k8sNodeFilterName: login\n                sshdServiceType: \"LoadBalancer\"\n                sshdServiceAnnotations:\n                  \"nebius.com/load-balancer-allocation-id\": \"vpcallocation-e02a0ac45he90zy9e3\"\n                sshdConfigMapRefName: \"\"\n                sshRootPublicKeys:\n                  - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIBx9GTsQyOngl1GO4WmnfJLakPKP2AnfKtYtRXJ7kI+0 nebius-demo-soperator\n                sshd:\n                  resources:\n                    cpu: 14000m\n                    memory: 54Gi\n                    ephemeralStorage: 164Gi\n                munge:\n                  resources:\n                    cpu: 100m\n                    memory: 0.5Gi\n                    ephemeralStorage: 5Gi\n                customInitContainers:\n                  - name: ensure-jail-virtiofs\n                    image: cr.eu-north1.nebius.cloud/soperator/busybox\n                    volumeMounts: [{ name: jail, mountPath: /volume-mount }]\n                    command: [\"grep\", \" /volume-mount virtiofs \", \"/proc/mounts\"]\n                  - name: ensure-jail-submount-data-virtiofs\n                    image: cr.eu-north1.nebius.cloud/soperator/busybox\n                    volumeMounts: [{ name: 'data', mountPath: /volume-mount }]\n                    command: [\"grep\", \" /volume-mount virtiofs \", \"/proc/mounts\"]\n                volumes:\n                  jailSubMounts:\n                    - mountPath: /home\n                      name: home-dir\n                      volumeSourceName: home-dir\n                    - mountPath: /etc/update-motd.d/95-nebius-o11y\n                      subPath: 95-nebius-o11y\n                      readOnly: true\n                      name: motd-nebius-o11y\n                      volumeSourceName: motd-nebius-o11y\n                    - name: data\n                      mountPath: /data\n                      volumeSourceName: jail-submount-data\n                  customMounts:\n                    - name: sys-host\n                      mountPath: /mnt/jail.upper/sys-host\n                      readOnly: true\n                      volumeSourceName: sys-host\n\n              exporter:\n                enabled: true\n                k8sNodeFilterName: system\n                exporterContainer:\n                  resources:\n                    cpu: 250m\n                    memory: 0.25Gi\n                    ephemeralStorage: 0.5Gi\n\n              rest:\n                enabled: true\n                k8sNodeFilterName: system\n                size: 2\n                rest:\n                  resources:\n                    cpu: 2000m\n                    memory: 8Gi\n                    ephemeralStorage: 0.5Gi\n                customInitContainers:\n                  - name: ensure-jail-virtiofs\n                    image: cr.eu-north1.nebius.cloud/soperator/busybox\n                    volumeMounts: [{ name: jail, mountPath: /volume-mount }]\n                    command: [\"grep\", \" /volume-mount virtiofs \", \"/proc/mounts\"]\n\n            sConfigController:\n              node:\n                k8sNodeFilterName: system\n                size: 2\n              container:\n                imagePullPolicy: IfNotPresent\n                resources:\n                  cpu: 250m\n                  memory: 256Mi\n                  ephemeralStorage: 500Mi\n\n          slurmClusterStorage:\n            enabled: true\n            interval: 5m\n            timeout: 5m\n            overrideValues:\n              volume:\n                controllerSpool:\n                  size: 24Gi\n                  filestoreDeviceName: controller-spool\n                jail:\n                  size: 300Gi\n                  filestoreDeviceName: jail\n                jailSubMounts:\n                  - name: data\n                    size: 600Gi\n                    filestoreDeviceName: jail-submount-data\n                accounting:\n                  enabled: true\n                  size: 100Gi\n                  filestoreDeviceName: accounting\n\n              storage:\n                accounting:\n                  matchExpressions:\n                    - key: slurm.nebius.ai/nodeset\n                      operator: In\n                      values:\n                        - accounting\n                  tolerations:\n                    - key: slurm.nebius.ai/nodeset\n                      operator: Equal\n                      value: accounting\n                      effect: NoSchedule\n\n                controllerSpool:\n                  matchExpressions:\n                    - key: slurm.nebius.ai/nodeset\n                      operator: In\n                      values:\n                        - controller\n                  tolerations:\n                    - key: slurm.nebius.ai/nodeset\n                      operator: Equal\n                      value: controller\n                      effect: NoSchedule\n\n                jail:\n                  matchExpressions:\n                    - key: slurm.nebius.ai/jail\n                      operator: In\n                      values:\n                        - \"true\"\n                  tolerations:\n                    - key: slurm.nebius.ai/nodeset\n                      operator: Exists\n                      effect: NoSchedule\n                    - key: nvidia.com/gpu\n                      operator: Exists\n                      effect: NoSchedule\n\n        soperatorActiveChecks:\n          enabled: true\n          interval: 5m\n          timeout: 120m\n          version: 4.1.0\n          releaseName: soperator-activechecks\n          namespace: soperator\n          overrideValues:\n            slurmClusterRefName: soperator\n            checks:\n              ensure-dir-snccld-logs:\n                enabled: true\n              \"all-reduce-perf-nccl-in-docker\":\n                \"runAfterCreation\": false\n              \"all-reduce-perf-nccl-with-ib\":\n                \"runAfterCreation\": false\n              \"all-reduce-perf-nccl-without-ib\":\n                \"runAfterCreation\": false\n              \"cuda-samples\":\n                \"runAfterCreation\": false\n              \"dcgmi-diag-r2\":\n                \"runAfterCreation\": false\n              \"dcgmi-diag-r3\":\n                \"runAfterCreation\": false\n              \"gpu-fryer\":\n                \"runAfterCreation\": false\n              \"ib-gpu-perf\":\n                \"commentPrefix\": \"[node_problem]\"\n                \"drainReasonPrefix\": null\n                \"runAfterCreation\": false\n              \"manage-jail-state\":\n                \"runAfterCreation\": false\n              \"mem-perf\":\n                \"runAfterCreation\": false\n              \"prepull-container-image\":\n                \"runAfterCreation\": false\n              \"ssh-check\":\n                \"k8sJobSpec\":\n                  \"jobContainer\":\n                    \"env\":\n                    - \"name\": \"NUM_OF_LOGIN_NODES\"\n                      \"value\": \"1\"\n              \n            cudaVersion: 13.0.2\n\n        soperator:\n          enabled: true\n          interval: 5m\n          timeout: 5m\n          version: 4.1.0\n          values:\n            manager:\n              resources:\n                requests:\n                  memory: 2Gi\n                  cpu: 1000m\n                limits:\n                  memory: 2Gi\n          kruise:\n            enabled: true\n            interval: 5m\n            timeout: 5m\n            overrideValues:\n              manager:\n                image:\n                  repository: cr.eu-north1.nebius.cloud/soperator/kruise-manager\n              helmHooks:\n                image:\n                  repository: cr.eu-north1.nebius.cloud/soperator/kruise-helm-hook\n          soperatorChecks:\n            enabled: true\n            interval: 5m\n            timeout: 5m\n            values:\n              checks:\n                manager:\n                  enableNodeReplacement: true\n                  enableExtensiveCheck: true\n                  env:\n                    maintenanceIgnoreNodeLabels: \"slurm.nebius.ai/nodeset=controller,slurm.nebius.ai/nodeset=nfs\"\n                  resources:\n                    requests:\n                      memory: 2Gi\n                      cpu: 1000m\n                    limits:\n                      memory: 2Gi\n          nodeConfigurator:\n            enabled: true\n            interval: 5m\n            timeout: 5m\n            values:\n              resources:\n                requests:\n                  memory: 0.25Gi\n                  cpu: 500m\n                limits:\n                  memory: 0.25Gi\n\n        notifier:\n          enabled: false\n\n        nfsServer:\n          enabled: true\n          version: 1.2.0\n          overrideValues:\n            image:\n              repository: cr.eu-north1.nebius.cloud/soperator/nfs-server\n              tag: 1.2.0\n            nameOverride: nfs-server\n            nfs:\n              sharedDirectory: \"/exported\"\n              shareOptions: \"rw,fsid=0,async,no_subtree_check,no_auth_nlm,insecure,no_root_squash\"\n              threads: \"64\"\n            storage:\n              storageClassName: \"compute-csi-network-ssd-io-m3-ext4\"\n              size: 558Gi\n            storageClass:\n              name: nfs\n            resources:\n              requests:\n                memory: 113Gi\n                cpu: 31000m\n              limits:\n                memory: 113Gi\n            nodeSelector:\n              slurm.nebius.ai/nodeset: nfs\n            tolerations:\n              - key: slurm.nebius.ai/nodeset\n                operator: Equal\n                value: nfs\n                effect: NoSchedule\n            monitoring:\n              enabled: true\n              serviceMonitor:\n                enabled: true\n        tailscale:\n          enabled: false\n\n        nodesets:\n          enabled: true\n        \n          interval: 5m\n          timeout: 5m\n          version: 4.1.0\n          namespace: soperator\n          releaseName: soperator-nodesets\n        \n          overrideValues: \n            nodesets:\n              - name: worker\n                annotations:\n                  slurm.nebius.ai/parental-cluster-ref: soperator\n        \n                replicas: 2\n                maxUnavailable: 20%\n        \n                gpu:\n                  enabled: true\n                  nvidia:\n                    gdrCopyEnabled: true\n        \n                nodeConfig:\n                  features:\n                    - gpu_h200_sxm\n                    - network_ssd\n                  static: \"CPUs=128 Boards=1 SocketsPerBoard=2 CoresPerSocket=32 ThreadsPerCore=2 Gres=gpu:nvidia_h200:8\"\n                  dynamic: \"\\\"{ \\\\\\\"ib_pod\\\\\\\": \\\\\\\"$TOPO_SWITCH_TIER2\\\\\\\", \\\\\\\"ib_su\\\\\\\": \\\\\\\"$TOPO_SWITCH_TIER1\\\\\\\" }\\\"\"\n                  gresConfig:\n                    - AutoDetect=off Name=gpu Type=nvidia_h200 File=/dev/nvidia4 Cores=0-31 Links=-1,1,1,1,1,1,1,1 Flags=nvidia_gpu_env\n                    - AutoDetect=off Name=gpu Type=nvidia_h200 File=/dev/nvidia5 Cores=0-31 Links=1,-1,1,1,1,1,1,1 Flags=nvidia_gpu_env\n                    - AutoDetect=off Name=gpu Type=nvidia_h200 File=/dev/nvidia6 Cores=0-31 Links=1,1,-1,1,1,1,1,1 Flags=nvidia_gpu_env\n                    - AutoDetect=off Name=gpu Type=nvidia_h200 File=/dev/nvidia7 Cores=0-31 Links=1,1,1,-1,1,1,1,1 Flags=nvidia_gpu_env\n                    - AutoDetect=off Name=gpu Type=nvidia_h200 File=/dev/nvidia0 Cores=32-63 Links=1,1,1,1,-1,1,1,1 Flags=nvidia_gpu_env\n                    - AutoDetect=off Name=gpu Type=nvidia_h200 File=/dev/nvidia1 Cores=32-63 Links=1,1,1,1,1,-1,1,1 Flags=nvidia_gpu_env\n                    - AutoDetect=off Name=gpu Type=nvidia_h200 File=/dev/nvidia2 Cores=32-63 Links=1,1,1,1,1,1,-1,1 Flags=nvidia_gpu_env\n                    - AutoDetect=off Name=gpu Type=nvidia_h200 File=/dev/nvidia3 Cores=32-63 Links=1,1,1,1,1,1,1,-1 Flags=nvidia_gpu_env\n        \n                slurmd:\n                  customEnv:\n                    - name: \"NVIDIA_DRIVER_CAPABILITIES\"\n                      value: \"compute,graphics,utility,video\"\n                  resources:\n                    cpu: 125950m\n                    memory: 1436Gi\n                    ephemeralStorage: 382Gi\n                    gpu: 8\n        \n                  volumes:\n                    spool:\n                      emptyDir: {}\n        \n                    jail:\n                      persistentVolumeClaim:\n                        claimName: jail-pvc\n                        readOnly: false\n        \n                    jailSubMounts:\n        \n                      - name: home-dir\n                        mountPath: /home\n                        volumeSource:\n                          persistentVolumeClaim:\n                            claimName: home-dir\n        \n                      - name: data\n                        mountPath: /data\n                        volumeSource:\n                          persistentVolumeClaim:\n                            claimName: jail-submount-data-pvc\n                            readOnly: false\n        \n                      - name: scratch\n                        mountPath: /scratch\n                        volumeClaimTemplateSpec:\n                          accessModes:\n                            - ReadWriteOnce\n                          storageClassName: compute-csi-network-ssd-ext4\n                          resources:\n                            requests:\n                              storage: 1024Gi\n        \n        \n        \n                    persistentVolumeClaimRetentionPolicy:\n                      whenDeleted: Delete\n                      whenScaled: Delete\n        \n                    customVolumeMounts:\n                      - name: slurm-scripts\n                        mountPath: /opt/slurm_scripts/\n                        volumeSource:\n                          configMap:\n                            name: slurm-scripts\n                            defaultMode: 0755\n        \n                      - name: slurm-scripts-jail\n                        mountPath: /mnt/jail.upper/opt/slurm_scripts/\n                        volumeSource:\n                          configMap:\n                            name: slurm-scripts\n                            defaultMode: 0755\n        \n                      - name: sys-host\n                        mountPath: /mnt/jail.upper/sys-host\n                        readOnly: true\n                        volumeSource:\n                          hostPath:\n                            path: /sys\n                            type: Directory\n        \n        \n                      - name: hpc-jobs-dir\n                        mountPath: /var/run/nebius/slurm\n                        volumeSource:\n                          hostPath:\n                            path: /var/run/nebius/slurm\n                            type: DirectoryOrCreate\n        \n                      - name: nvidia-driver-root\n                        mountPath: /run/nvidia/driver\n                        readOnly: false\n                        volumeSource:\n                          hostPath:\n                            path: /\n                            type: \"\"\n        \n                    sharedMemorySize: 64Gi\n        \n                  security:\n                    appArmorProfile: unconfined\n        \n                munge:\n                  resources:\n                    cpu: 100m\n                    memory: 0.5Gi\n                    ephemeralStorage: 5Gi\n        \n                  security:\n                    appArmorProfile: unconfined\n        \n                sssd:\n                  enabled: false\n                  resources:\n                    cpu: 200m\n                    memory: 0.5Gi\n                    ephemeralStorage: 5Gi\n        \n                sssdConfSecretRefName: \"\"\n                sssdLdapCAConfigMapRefName: \"\"\n        \n                configMapRefSupervisord: custom-supervisord-config\n                configMapRefSshd: \n        \n                enableHostUserNamespace: true\n        \n                priorityClass: soperator-worker-high-priority\n                nodeSelector:\n                  slurm.nebius.ai/nodeset-name: worker\n                tolerations:\n                  - key: nvidia.com/gpu\n                    operator: Exists\n                    effect: NoSchedule\n        \n                customInitContainers:\n                  - name: ensure-jail-virtiofs\n                    image: cr.eu-north1.nebius.cloud/soperator/busybox\n                    volumeMounts: [{ name: jail, mountPath: /volume-mount }]\n                    command: [\"grep\", \" /volume-mount virtiofs \", \"/proc/mounts\"]\n        \n                  - name: ensure-jail-submount-data-virtiofs\n                    image: cr.eu-north1.nebius.cloud/soperator/busybox\n                    volumeMounts: [{ name: 'data', mountPath: /volume-mount }]\n                    command: [\"grep\", \" /volume-mount virtiofs \", \"/proc/mounts\"]\n        \n                  - name: ensure-node-local-jail-submount-scratch-ext4\n                    image: cr.eu-north1.nebius.cloud/soperator/busybox\n                    volumeMounts: [{ name: 'scratch', mountPath: /volume-mount }]\n                    command: [\"grep\", ' /volume-mount ext4 ', \"/proc/mounts\"]\n        \n        \n        \n\n"
            ],
            "verify": false,
            "version": "2.0.0",
            "wait": true,
            "wait_for_jobs": false
          },
          "sensitive_attributes": [
            [
              {
                "type": "get_attr",
                "value": "repository_password"
              }
            ]
          ],
          "identity_schema_version": 0,
          "private": "eyJzY2hlbWFfdmVyc2lvbiI6IjEifQ==",
          "dependencies": [
            "data.nebius_compute_v1_filesystem.existing_jail",
            "data.nebius_iam_v1_project.this",
            "data.nebius_vpc_v1_subnet.this",
            "module.backups.data.nebius_iam_v1_group.editors",
            "module.backups.nebius_iam_v1_group_membership.backups_service_account_group",
            "module.backups.nebius_iam_v1_service_account.backups_service_account",
            "module.backups.terraform_data.k8s_backups_bucket_access_secret",
            "module.backups_store.nebius_storage_v1_bucket.backups_bucket",
            "module.backups_store.terraform_data.cleanup_bucket",
            "module.cleanup.terraform_data.disk_cleanup",
