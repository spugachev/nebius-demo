            "template": {
              "boot_disk": {
                "block_size_bytes": 4096,
                "size_bytes": 549755813888,
                "size_gibibytes": null,
                "size_kibibytes": null,
                "size_mebibytes": null,
                "type": "NETWORK_SSD"
              },
              "cloud_init_user_data": "#cloud-config\n\n\n\n\n\nwrite_files:\n\n  - path: /etc/modprobe.d/nvidia_config.conf\n    owner: root:root\n    permissions: \"0644\"\n    content: |\n\n      options nvidia NVreg_RestrictProfilingToAdminUsers=0\n\n      options nvidia NVreg_EnableStreamMemOPs=1\n\n      options nvidia NVreg_RegistryDwords=\"PeerMappingOverride=1;\"\n\n  - path: /usr/local/bin/nvidia-config-check.sh\n    owner: root:root\n    permissions: \"0755\"\n    content: |\n        #!/usr/bin/env bash\n        set -euo pipefail\n\n        modprobe_conf=\"/etc/modprobe.d/nvidia_config.conf\"\n        params_file=\"/proc/driver/nvidia/params\"\n\n        log_prefix=\"[nvidia-config]\"\n        log() {\n            echo \"${log_prefix} $(date -u +%Y-%m-%dT%H:%M:%SZ) $*\"\n        }\n\n        trim() {\n            local value=\"${1:-}\"\n            value=\"${value#\"${value%%[![:space:]]*}\"}\"\n            value=\"${value%\"${value##*[![:space:]]}\"}\"\n            printf '%s\\n' \"${value}\"\n        }\n\n        unquote() {\n            local value\n            value=\"$(trim \"${1:-}\")\"\n            if [[ \"${value}\" =~ ^\\\"(.*)\\\"$ ]]; then\n                printf '%s\\n' \"${BASH_REMATCH[1]}\"\n                return\n            fi\n            if [[ \"${value}\" =~ ^\\'(.*)\\'$ ]]; then\n                printf '%s\\n' \"${BASH_REMATCH[1]}\"\n                return\n            fi\n            printf '%s\\n' \"${value}\"\n        }\n\n        normalize_param_name() {\n            local key=\"${1:-}\"\n            case \"${key}\" in\n                NVreg_RestrictProfilingToAdminUsers)\n                    printf '%s\\n' \"RmProfilingAdminOnly\"\n                    ;;\n                NVreg_*)\n                    printf '%s\\n' \"${key#NVreg_}\"\n                    ;;\n                *)\n                    printf '%s\\n' \"${key}\"\n                    ;;\n            esac\n        }\n\n        declare -A current_params=()\n\n        load_current_params() {\n            local line key value\n\n            while IFS= read -r line; do\n                line=\"$(trim \"${line}\")\"\n                [[ -n \"${line}\" ]] || continue\n\n                if [[ \"${line}\" == *:* ]]; then\n                    key=\"$(trim \"${line%%:*}\")\"\n                    value=\"$(trim \"${line#*:}\")\"\n                    current_params[\"${key}\"]=\"$(unquote \"${value}\")\"\n                fi\n            done \u003c \"${params_file}\"\n        }\n\n        current_param_value() {\n            local key=\"${1:-}\" registry_dwords\n            if [[ -v current_params[\"${key}\"] ]]; then\n                printf '%s\\n' \"${current_params[\"${key}\"]}\"\n                return\n            fi\n\n            # Nested values under RegistryDwords are checked separately\n            if [[ -v current_params[\"RegistryDwords\"] ]]; then\n                registry_dwords=\"${current_params[\"RegistryDwords\"]}\"\n                printf '%s\\n' \"${registry_dwords}\" | grep -Eo \"(^|[[:space:];])${key}=[^[:space:];\\\"]+\" | tail -n1 | sed -E \"s/(^|[[:space:];])${key}=//\" || true\n            fi\n        }\n\n        check_param() {\n            local key=\"${1:-}\" desired_raw=\"${2:-}\" normalized_key desired current\n\n            normalized_key=\"$(normalize_param_name \"${key}\")\"\n            desired=\"$(unquote \"${desired_raw}\")\"\n            current=\"$(current_param_value \"${normalized_key}\")\"\n\n            log \"check key=${normalized_key} desired=${desired:-unknown} current=${current:-missing}\"\n\n            if [[ -z \"${current}\" ]]; then\n                log \"mismatch=${normalized_key} reason=missing desired=${desired}\"\n                return 1\n            fi\n\n            if [[ \"${current}\" != \"${desired}\" ]]; then\n                log \"mismatch=${normalized_key} desired=${desired} current=${current}\"\n                return 1\n            fi\n\n            return 0\n        }\n\n        parse_and_check_option() {\n            local key=\"${1:-}\" value=\"${2:-}\" registry_entry registry_key registry_value rc=0\n\n            if [[ \"${key}\" == \"NVreg_RegistryDwords\" ]]; then\n                while IFS= read -r registry_entry; do\n                    registry_entry=\"$(trim \"${registry_entry}\")\"\n                    [[ -n \"${registry_entry}\" ]] || continue\n                    registry_key=\"${registry_entry%%=*}\"\n                    registry_value=\"${registry_entry#*=}\"\n                    if ! check_param \"${registry_key}\" \"${registry_value}\"; then\n                        rc=1\n                    fi\n                done \u003c \u003c(printf '%s\\n' \"$(unquote \"${value}\")\" | tr ';' '\\n')\n                return \"${rc}\"\n            fi\n\n            if [[ \"${key}\" == \"NVreg_RegistryDwordsPerDevice\" ]]; then\n                log \"status=skip reason=unsupported_device_scoped_option key=${key} value=${value@Q}\"\n                return 0\n            fi\n\n            check_param \"${key}\" \"${value}\"\n        }\n\n        log \"start\"\n\n        if [ ! -f \"${modprobe_conf}\" ]; then\n            log \"status=skip reason=missing_conf file=${modprobe_conf}\"\n            exit 0\n        fi\n\n        if [ ! -r \"${params_file}\" ]; then\n            log \"status=skip reason=nvidia_params_missing\"\n            exit 0\n        fi\n\n        load_current_params\n\n        mismatch=0\n        while IFS= read -r raw_line; do\n            line=\"$(trim \"${raw_line%%#*}\")\"\n            [[ -n \"${line}\" ]] || continue\n\n            # Match an options line like:\n            # options nvidia NVreg_EnableMSI=1 NVreg_RmLogonRC=0\n            if [[ ! \"${line}\" =~ ^options[[:space:]]+nvidia[[:space:]]+(.+)$ ]]; then\n                log \"status=skip reason=unsupported_line line=${line@Q}\"\n                continue\n            fi\n\n            line=\"${BASH_REMATCH[1]}\"\n            while [[ -n \"${line}\" ]]; do\n                # Match a double-quoted value like:\n                # NVreg_RegistryDwords=\"RmLogonRC=0;RmMsg=0x1\"\n                if [[ \"${line}\" =~ ^([A-Za-z0-9_]+)=\\\"([^\\\"]*)\\\"[[:space:]]*(.*)$ ]]; then\n                    key=\"${BASH_REMATCH[1]}\"\n                    value=\"${BASH_REMATCH[2]}\"\n                    line=\"${BASH_REMATCH[3]}\"\n                # Match a single-quoted value like:\n                # NVreg_TemporaryFilePath='/var/tmp/nvidia'\n                elif [[ \"${line}\" =~ ^([A-Za-z0-9_]+)=\\'([^\\']*)\\'[[:space:]]*(.*)$ ]]; then\n                    key=\"${BASH_REMATCH[1]}\"\n                    value=\"${BASH_REMATCH[2]}\"\n                    line=\"${BASH_REMATCH[3]}\"\n                # Match an unquoted scalar like:\n                # NVreg_EnableStreamMemOPs=1\n                elif [[ \"${line}\" =~ ^([A-Za-z0-9_]+)=([^[:space:]]+)[[:space:]]*(.*)$ ]]; then\n                    key=\"${BASH_REMATCH[1]}\"\n                    value=\"${BASH_REMATCH[2]}\"\n                    line=\"${BASH_REMATCH[3]}\"\n                else\n                    log \"status=skip reason=unparsed_segment segment=${line@Q}\"\n                    mismatch=1\n                    break\n                fi\n\n                if ! parse_and_check_option \"${key}\" \"${value}\"; then\n                    mismatch=1\n                fi\n            done\n        done \u003c \"${modprobe_conf}\"\n\n        if [ \"${mismatch}\" -eq 1 ]; then\n            log \"action=reboot (mismatch)\"\n            shutdown -r +1 \"cloud-init: apply /etc/modprobe.d/nvidia_config.conf\"\n        else\n            log \"status=ok\"\n        fi\n\n        log \"end\"\n\n\n\n\n\nruncmd:\n\n  - [ bash, -lc, \"/usr/local/bin/nvidia-config-check.sh \u003e\u003e /var/log/nvidia-config-check.log 2\u003e\u00261\" ]\n\n\n\n",
