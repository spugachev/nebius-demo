    {
      "module": "module.slurm",
      "mode": "managed",
      "type": "helm_release",
      "name": "soperator_fluxcd_cm",
      "provider": "provider[\"registry.terraform.io/hashicorp/helm\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "atomic": false,
            "chart": "raw",
            "cleanup_on_fail": false,
            "create_namespace": false,
            "dependency_update": false,
            "description": null,
            "devel": null,
            "disable_crd_hooks": false,
            "disable_openapi_validation": false,
            "disable_webhooks": false,
            "force_update": false,
            "id": "terraform-fluxcd-values",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": [
              {
                "app_version": "1.0.0",
                "chart": "raw",
                "first_deployed": 1782244065,
                "last_deployed": 1782244065,
                "name": "terraform-fluxcd-values",
                "namespace": "flux-system",
                "notes": "",
                "revision": 1,
                "values": "{\"resources\":[{\"apiVersion\":\"v1\",\"data\":{\"values.yaml\":\"helmRepository:\\n  interval: 15m\\n  nfsServer:\\n    url: oci://cr.eu-north1.nebius.cloud/soperator\\n  soperator:\\n    url: oci://cr.eu-north1.nebius.cloud/soperator\\ncertManager:\\n  enabled: true\\n  interval: 5m\\n  timeout: 5m\\nbackup:\\n  enabled: true\\n  interval: 5m\\n  timeout: 5m\\n  config:\\n    enabled: true\\n    version: 4.1.0\\n    values:\\n      secret:\\n        name: jail-backup\\n      bucket:\\n        endpoint: https://storage.eu-north2.nebius.cloud:443\\n        name: soperator-spugachev-backups\\n      backup:\\n        schedule: \\\"@daily-random\\\"\\n      prune:\\n        schedule: \\\"@daily-random\\\"\\n      retention:\\n        keepDaily: 3\\n\\nmariadbOperator:\\n  enabled: true\\n  interval: 5m\\n  timeout: 5m\\n  version: 25.10.2\\n  values: null\\nobservability:\\n  enabled: true\\n  clusterName: spugachev\\n  publicEndpointEnabled: false\\n  region: eu-north2\\n  opentelemetry:\\n    enabled: true\\n    logs:\\n      values:\\n        resources:\\n          requests:\\n            memory: 200Mi\\n            cpu: 200m\\n          limits:\\n            memory: 200Mi\\n        jailLogs:\\n          enabled: true\\n          resources:\\n            requests:\\n              memory: 1Gi\\n              cpu: 1000m\\n            limits:\\n              memory: 1Gi\\n\\n    events:\\n      interval: 5m\\n      timeout: 5m\\n      values:\\n        resources:\\n          requests:\\n            memory: 128Mi\\n            cpu: 100m\\n          limits:\\n            memory: 128Mi\\n  prometheusOperator:\\n    enabled: true\\n    interval: 5m\\n    timeout: 5m\\n  vmStack:\\n    enabled: true\\n    crds:\\n      interval: 5m\\n      timeout: 5m\\n    interval: 5m\\n    timeout: 5m\\n    values:\\n      vmagent:\\n        spec:\\n          extraArgs:\\n            promscrape.maxScrapeSize: \\\"33554432\\\"\\n          externalLabels:\\n            iam_tenant_id: tenant-e00znpks4hqd7c0e72\\n            iam_project_id: project-e02qk7z0pr005jndcar132\\n            mk8s_cluster_id: mk8scluster-e02fv10y8fh5nghh2m\\n          resources:\\n            requests:\\n              memory: 10Gi\\n              cpu: 5000m\\n            limits:\\n              memory: 10Gi\\n      vmsingle:\\n        spec:\\n          extraArgs:\\n            dedup.minScrapeInterval: 30s\\n            maxLabelsPerTimeseries: \\\"40\\\"\\n            search.maxQueryLen: \\\"18765\\\"\\n            search.maxUniqueTimeseries: \\\"500000\\\"\\n          retentionPeriod: 7d\\n          extraEnvs:\\n          - name: GOMAXPROCS\\n            value: \\\"6\\\"\\n          storage:\\n            accessModes:\\n              - ReadWriteOnce\\n            resources:\\n              requests:\\n                storage: 512Gi\\n          resources:\\n            requests:\\n              memory: 24Gi\\n              cpu: 6000m\\n            limits:\\n              memory: 24Gi\\n      prometheusNodeExporter:\\n        enabled: true\\n        extraArgs:\\n          - '--collector.ethtool.device-exclude=ibp.*'\\n          - '--no-collector.infiniband'\\n  vmLogs:\\n    enabled: true\\n    interval: 5m\\n    timeout: 5m\\n    values:\\n      persistentVolume:\\n        enabled: true\\n        size: 256Gi\\n        accessMode: ReadWriteOnce\\n      resources:\\n        requests:\\n          memory: 2Gi\\n          cpu: 1000m\\n        limits:\\n          memory: 2Gi\\n  dcgmExporter:\\n    enabled: true\\n    version: 4.1.0\\n    values:\\n      hpcJobMapDir: /var/run/nebius/slurm\\n      # waits for nvidia toolkit when not running on preinstalled gpu drivers, so opposite of use_preinstalled_gpu_drivers\\n      validateToolkit: false\\n      resources:\\n        requests:\\n          memory: 0.5Gi\\n          cpu: 0.05m\\n        limits:\\n          memory: 0.5Gi\\n\\nsecurityProfilesOperator:\\n  enabled: true\\n  interval: 5m\\n  timeout: 5m\\n  values:\\n    daemon:\\n      resources:\\n        limits:\\n          memory: 128Mi\\n        requests:\\n          cpu: 100m\\n          memory: 128Mi\\n    resources:\\n      limits:\\n        cpu: 500m\\n        memory: 3Gi\\n      requests:\\n        cpu: 500m\\n        memory: 3Gi\\nslurmCluster:\\n  enabled: true\\n  interval: 5m\\n  timeout: 5m\\n  version: 4.1.0\\n  namespace: soperator\\n  releaseName: soperator\\n  overrideValues:\\n    clusterName: soperator\\n    cudaVersion: 13.0.2\\n    useDefaultAppArmorProfile: true\\n    maintenance: none\\n\\n\\n    partitionConfiguration:\\n      configType: structured\\n      partitions:\\n        - name: main\\n          isAll: true\\n          config: \\\"Default=YES PriorityTier=10 PreemptMode=OFF MaxTime=INFINITE State=UP OverSubscribe=YES\\\"\\n        - name: hidden\\n          isAll: true\\n          config: \\\"Default=NO PriorityTier=10 PreemptMode=OFF Hidden=YES MaxTime=INFINITE State=UP OverSubscribe=YES\\\"\\n\\n\\n    k8sNodeFilters:\\n      - name: system\\n        affinity:\\n          nodeAffinity:\\n            requiredDuringSchedulingIgnoredDuringExecution:\\n              nodeSelectorTerms:\\n                - matchExpressions:\\n                    - key: slurm.nebius.ai/nodeset\\n                      operator: In\\n                      values:\\n                        - system\\n\\n      - name: accounting\\n        affinity:\\n          nodeAffinity:\\n            requiredDuringSchedulingIgnoredDuringExecution:\\n              nodeSelectorTerms:\\n                - matchExpressions:\\n                    - key: slurm.nebius.ai/nodeset\\n                      operator: In\\n                      values:\\n                        - accounting\\n        tolerations:\\n          - key: slurm.nebius.ai/nodeset\\n            operator: Equal\\n            value: accounting\\n            effect: NoSchedule\\n\\n      - name: controller\\n        affinity:\\n          nodeAffinity:\\n            requiredDuringSchedulingIgnoredDuringExecution:\\n              nodeSelectorTerms:\\n                - matchExpressions:\\n                    - key: slurm.nebius.ai/nodeset\\n                      operator: In\\n                      values:\\n                        - controller\\n        tolerations:\\n          - key: slurm.nebius.ai/nodeset\\n            operator: Equal\\n            value: controller\\n            effect: NoSchedule\\n\\n      - name: login\\n        affinity:\\n          nodeAffinity:\\n            requiredDuringSchedulingIgnoredDuringExecution:\\n              nodeSelectorTerms:\\n                - matchExpressions:\\n                    - key: slurm.nebius.ai/nodeset\\n                      operator: In\\n                      values:\\n                        - login\\n        tolerations:\\n          - key: slurm.nebius.ai/nodeset\\n            operator: Equal\\n            value: login\\n            effect: NoSchedule\\n\\n      - name: worker\\n        affinity:\\n          nodeAffinity:\\n            requiredDuringSchedulingIgnoredDuringExecution:\\n              nodeSelectorTerms:\\n                - matchExpressions:\\n                    - key: slurm.nebius.ai/nodeset\\n                      operator: In\\n                      values:\\n                        - \\\"worker-0\\\"\\n        tolerations:\\n          - key: slurm.nebius.ai/nodeset\\n            operator: Equal\\n            value: worker\\n            effect: NoSchedule\\n          - key: nvidia.com/gpu\\n            operator: Exists\\n            effect: NoSchedule\\n\\n    volumeSources:\\n      - name: jail\\n        persistentVolumeClaim:\\n          claimName: jail-pvc\\n          readOnly: false\\n\\n      - name: controller-spool\\n        persistentVolumeClaim:\\n          claimName: controller-spool-pvc\\n          readOnly: false\\n\\n      - name: worker-spool\\n        emptyDir:\\n          sizeLimit: 382Gi\\n\\n\\n      - name: home-dir\\n        createPV